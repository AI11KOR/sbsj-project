## Required
OPENAI_API_KEY=

## Optional (MCP: Tavily)
TAVILY_API_KEY=

## Optional (MCP: Brave via Smithery CLI)
SMITHERY_BRAVE_KEY=
SMITHERY_BRAVE_PROFILE=

## Optional tuning
RAG_MODEL_NAME=gpt-4o-mini
RAG_TEMPERATURE=0.7
RAG_MAX_TOKENS=1000
RAG_TOP_K=3
RAG_SCORE_THRESHOLD=0.65

## Optional (ChromaDB persist directory)
## Windows에서 사용자 폴더 경로에 한글이 포함되면 Chroma 인덱스 파일을 못 여는 경우가 있어
## 영문 경로로 우회할 수 있습니다. 예) C:\\chroma_db\\1team
CHROMA_PERSIST_DIRECTORY=

## Optional (MCP tool-selection model)
MCP_TOOL_MODEL_NAME=gpt-4o-mini
MCP_TOOL_TEMPERATURE=0.3


