{
  "mcpServers": {
    "tavily": {
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_API_KEY}"
    },
    "brave": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@smithery/cli@latest",
        "run",
        "brave",
        "--key",
        "${SMITHERY_BRAVE_KEY}",
        "--profile",
        "${SMITHERY_BRAVE_PROFILE}"
      ]
    }
  }
}


